<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="reporte_tratamiento"
              pageWidth="595"
              pageHeight="842"
              columnWidth="515"
              leftMargin="40"
              rightMargin="40"
              topMargin="30"
              bottomMargin="30">

    <parameter name="LOGO_PATH" class="java.io.InputStream"/>
    <parameter name="NOMBRE_CLINICA" class="java.lang.String"/>
    <parameter name="FECHA_EMISION" class="java.lang.String"/>

    <parameter name="NUMERO_TRATAMIENTO" class="java.lang.String"/>
    <parameter name="PACIENTE" class="java.lang.String"/>
    <parameter name="DNI" class="java.lang.String"/>
    <parameter name="NRO_HISTORIA" class="java.lang.String"/>
    <parameter name="MEDICO" class="java.lang.String"/>
    <parameter name="ESPECIALIDAD" class="java.lang.String"/>
    <parameter name="FECHA_REGISTRO" class="java.lang.String"/>
    <parameter name="DIAGNOSTICO" class="java.lang.String"/>
    <parameter name="TRATAMIENTO" class="java.lang.String"/>
    <parameter name="OBSERVACIONES" class="java.lang.String"/>

    <title>
        <band height="760">

            <rectangle>
                <reportElement x="0" y="0" width="515" height="12" backcolor="#EA6248" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0"/>
                </graphicElement>
            </rectangle>

            <rectangle>
                <reportElement x="0" y="12" width="515" height="95" backcolor="#F4FCFD" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <image>
                <reportElement x="15" y="30" width="75" height="45"/>
                <imageExpression><![CDATA[$P{LOGO_PATH}]]></imageExpression>
            </image>

            <textField>
                <reportElement x="100" y="27" width="240" height="22"/>
                <textElement>
                    <font size="15" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{NOMBRE_CLINICA}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="100" y="54" width="260" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <text><![CDATA[Documento clínico de tratamiento del paciente]]></text>
            </staticText>

            <textField>
                <reportElement x="100" y="72" width="260" height="16"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Fecha de emisión: " + $P{FECHA_EMISION}]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement x="355" y="27" width="140" height="60" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="1.1" lineColor="#333333"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="355" y="35" width="140" height="18"/>
                <textElement textAlignment="Center">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[TRATAMIENTO]]></text>
            </staticText>

            <textField>
                <reportElement x="355" y="58" width="140" height="18"/>
                <textElement textAlignment="Center">
                    <font size="10" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{NUMERO_TRATAMIENTO}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="130" width="515" height="30" backcolor="#00A199" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="13" isBold="true"/>
                </textElement>
                <text><![CDATA[REPORTE DE TRATAMIENTO MÉDICO]]></text>
            </staticText>

            <rectangle>
                <reportElement x="0" y="185" width="515" height="165" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="0" y="185" width="515" height="24" backcolor="#EAFBFD" mode="Opaque"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[  DATOS DEL PACIENTE Y ATENCIÓN]]></text>
            </staticText>

            <staticText>
                <reportElement x="25" y="225" width="120" height="16"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Paciente:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="225" width="330" height="16"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{PACIENTE}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="250" width="120" height="16"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[DNI:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="250" width="330" height="16"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{DNI}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="275" width="120" height="16"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Historia clínica:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="275" width="330" height="16"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{NRO_HISTORIA}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="300" width="120" height="16"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Médico tratante:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="300" width="330" height="16"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{MEDICO}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="325" width="120" height="16"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Especialidad:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="325" width="330" height="16"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{ESPECIALIDAD}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="375" width="515" height="24" backcolor="#00A199" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[  PLAN DE TRATAMIENTO]]></text>
            </staticText>

            <rectangle>
                <reportElement x="0" y="399" width="515" height="235" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="25" y="425" width="120" height="16"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Diagnóstico base:]]></text>
            </staticText>

            <textField isStretchWithOverflow="true">
                <reportElement x="155" y="425" width="330" height="40"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{DIAGNOSTICO}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="20" y="480" width="475" height="1"/>
                <graphicElement>
                    <pen lineWidth="0.4" lineColor="#E0E0E0"/>
                </graphicElement>
            </line>

            <staticText>
                <reportElement x="25" y="500" width="120" height="16"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Tratamiento:]]></text>
            </staticText>

            <textField isStretchWithOverflow="true">
                <reportElement x="155" y="500" width="330" height="50"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{TRATAMIENTO}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="20" y="565" width="475" height="1"/>
                <graphicElement>
                    <pen lineWidth="0.4" lineColor="#E0E0E0"/>
                </graphicElement>
            </line>

            <staticText>
                <reportElement x="25" y="585" width="120" height="16"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Observaciones:]]></text>
            </staticText>

            <textField isStretchWithOverflow="true">
                <reportElement x="155" y="585" width="330" height="35"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{OBSERVACIONES}]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement x="0" y="655" width="515" height="48" backcolor="#F4FCFD" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="20" y="667" width="475" height="24"/>
                <textElement textAlignment="Center">
                    <font size="8" isItalic="true"/>
                </textElement>
                <text><![CDATA[Este reporte corresponde al plan de tratamiento indicado por el profesional de salud. Debe seguirse según la indicación médica.]]></text>
            </staticText>

            <line>
                <reportElement x="55" y="737" width="170" height="1"/>
                <graphicElement>
                    <pen lineWidth="0.8" lineColor="#333333"/>
                </graphicElement>
            </line>

            <staticText>
                <reportElement x="55" y="738" width="170" height="14"/>
                <textElement textAlignment="Center">
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Firma del médico tratante]]></text>
            </staticText>

            <line>
                <reportElement x="290" y="737" width="170" height="1"/>
                <graphicElement>
                    <pen lineWidth="0.8" lineColor="#333333"/>
                </graphicElement>
            </line>

            <staticText>
                <reportElement x="290" y="738" width="170" height="14"/>
                <textElement textAlignment="Center">
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Clínica Sanicen]]></text>
            </staticText>

        </band>
    </title>

</jasperReport>