<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="reporte_citas_especialidad"
              pageWidth="595"
              pageHeight="842"
              columnWidth="515"
              leftMargin="40"
              rightMargin="40"
              topMargin="30"
              bottomMargin="30">

    <parameter name="LOGO_PATH" class="java.io.InputStream"/>
    <parameter name="NOMBRE_CLINICA" class="java.lang.String"/>
    <parameter name="TITULO" class="java.lang.String"/>
    <parameter name="FECHA_INICIO" class="java.lang.String"/>
    <parameter name="FECHA_FIN" class="java.lang.String"/>
    <parameter name="TOTAL_CITAS" class="java.lang.String"/>

    <field name="especialidad" class="java.lang.String"/>
    <field name="cantidad" class="java.lang.Long"/>

    <title>
        <band height="205">

            <rectangle>
                <reportElement x="0" y="0" width="515" height="10" backcolor="##EA6248" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0"/>
                </graphicElement>
            </rectangle>

            <rectangle>
                <reportElement x="0" y="10" width="515" height="90" backcolor="#F8F9FA" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <image>
                <reportElement x="15" y="30" width="75" height="40"/>
                <imageExpression><![CDATA[$P{LOGO_PATH}]]></imageExpression>
            </image>

            <textField>
                <reportElement x="105" y="30" width="250" height="24"/>
                <textElement>
                    <font size="15" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{NOMBRE_CLINICA}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="105" y="58" width="300" height="18"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <text><![CDATA[Sistema de gestión de citas médicas]]></text>
            </staticText>

            <textField>
                <reportElement x="0" y="125" width="515" height="30" backcolor="#E8505B" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="13" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{TITULO}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="170" width="300" height="18"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Periodo: " + $P{FECHA_INICIO} + " al " + $P{FECHA_FIN}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="335" y="170" width="180" height="18"/>
                <textElement textAlignment="Right">
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Total de citas: " + $P{TOTAL_CITAS}]]></textFieldExpression>
            </textField>

        </band>
    </title>

    <columnHeader>
        <band height="35">

            <rectangle>
                <reportElement x="0" y="0" width="515" height="28" backcolor="#F1F1F1" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#CCCCCC"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="20" y="7" width="300" height="16"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Especialidad médica]]></text>
            </staticText>

            <staticText>
                <reportElement x="360" y="7" width="120" height="16"/>
                <textElement textAlignment="Right">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Cantidad de citas]]></text>
            </staticText>

        </band>
    </columnHeader>

    <detail>
        <band height="32">

            <line>
                <reportElement x="0" y="30" width="515" height="1"/>
                <graphicElement>
                    <pen lineWidth="0.4" lineColor="#E0E0E0"/>
                </graphicElement>
            </line>

            <textField>
                <reportElement x="20" y="7" width="300" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{especialidad}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="360" y="7" width="120" height="16"/>
                <textElement textAlignment="Right">
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{cantidad}.toString()]]></textFieldExpression>
            </textField>

        </band>
    </detail>

    <summary>
        <band height="110">

            <rectangle>
                <reportElement x="315" y="20" width="180" height="42" backcolor="#F8F9FA" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="1.0" lineColor="#333333"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="330" y="34" width="85" height="16"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[TOTAL CITAS:]]></text>
            </staticText>

            <textField>
                <reportElement x="415" y="34" width="60" height="16"/>
                <textElement textAlignment="Right">
                    <font size="10" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{TOTAL_CITAS}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="0" y="80" width="515" height="1"/>
            </line>

            <staticText>
                <reportElement x="0" y="92" width="515" height="14"/>
                <textElement textAlignment="Center">
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Documento generado automáticamente por el Sistema Clínica Sanicen.]]></text>
            </staticText>

        </band>
    </summary>

</jasperReport>