<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="reporte_receta_medica"
              pageWidth="595"
              pageHeight="842"
              columnWidth="515"
              leftMargin="40"
              rightMargin="40"
              topMargin="30"
              bottomMargin="30">

    <parameter name="LOGO_PATH" class="java.io.InputStream"/>
    <parameter name="NOMBRE_CLINICA" class="java.lang.String"/>
    <parameter name="FECHA_EMISION" class="java.lang.String"/>

    <parameter name="NUMERO_RECETA" class="java.lang.String"/>
    <parameter name="PACIENTE" class="java.lang.String"/>
    <parameter name="MEDICO" class="java.lang.String"/>
    <parameter name="ESPECIALIDAD" class="java.lang.String"/>
    <parameter name="FECHA_RECETA" class="java.lang.String"/>
    <parameter name="INDICACIONES" class="java.lang.String"/>

    <field name="medicamento" class="java.lang.String"/>
    <field name="dosis" class="java.lang.String"/>
    <field name="frecuencia" class="java.lang.String"/>
    <field name="duracion" class="java.lang.String"/>
    <field name="instrucciones" class="java.lang.String"/>

    <title>
        <band height="360">

            <rectangle>
                <reportElement x="0" y="0" width="515" height="10" backcolor="#E8505B" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0"/>
                </graphicElement>
            </rectangle>

            <rectangle>
                <reportElement x="0" y="10" width="515" height="95" backcolor="#F8F9FA" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <image>
                <reportElement x="15" y="28" width="75" height="45"/>
                <imageExpression><![CDATA[$P{LOGO_PATH}]]></imageExpression>
            </image>

            <textField>
                <reportElement x="100" y="25" width="240" height="22"/>
                <textElement>
                    <font size="15" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{NOMBRE_CLINICA}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="100" y="52" width="260" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <text><![CDATA[Documento de receta médica electrónica]]></text>
            </staticText>

            <textField>
                <reportElement x="100" y="70" width="260" height="16"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Fecha de emisión: " + $P{FECHA_EMISION}]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement x="355" y="25" width="140" height="60" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="1.1" lineColor="#333333"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="355" y="33" width="140" height="18"/>
                <textElement textAlignment="Center">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[RECETA MÉDICA]]></text>
            </staticText>

            <textField>
                <reportElement x="355" y="56" width="140" height="18"/>
                <textElement textAlignment="Center">
                    <font size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{NUMERO_RECETA}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="130" width="515" height="28" backcolor="#E8505B" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="13" isBold="true"/>
                </textElement>
                <text><![CDATA[RECETA MÉDICA ELECTRÓNICA]]></text>
            </staticText>

            <rectangle>
                <reportElement x="0" y="185" width="515" height="145" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="0" y="185" width="515" height="24" backcolor="#F1F1F1" mode="Opaque"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[  DATOS DE LA RECETA]]></text>
            </staticText>

            <staticText>
                <reportElement x="25" y="225" width="120" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Paciente:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="225" width="330" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{PACIENTE}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="253" width="120" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Médico:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="253" width="330" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{MEDICO}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="281" width="120" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Especialidad:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="281" width="330" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ESPECIALIDAD}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="309" width="120" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Fecha receta:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="309" width="330" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{FECHA_RECETA}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="345" width="515" height="15" backcolor="#E8505B" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[  DETALLE DE MEDICAMENTOS]]></text>
            </staticText>

        </band>
    </title>

    <columnHeader>
        <band height="32">

            <rectangle>
                <reportElement x="0" y="0" width="515" height="28" backcolor="#F1F1F1" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#CCCCCC"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="8" y="7" width="125" height="14"/>
                <textElement>
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Medicamento]]></text>
            </staticText>

            <staticText>
                <reportElement x="138" y="7" width="75" height="14"/>
                <textElement>
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Dosis]]></text>
            </staticText>

            <staticText>
                <reportElement x="218" y="7" width="90" height="14"/>
                <textElement>
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Frecuencia]]></text>
            </staticText>

            <staticText>
                <reportElement x="313" y="7" width="70" height="14"/>
                <textElement>
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Duración]]></text>
            </staticText>

            <staticText>
                <reportElement x="388" y="7" width="115" height="14"/>
                <textElement>
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Instrucciones]]></text>
            </staticText>

        </band>
    </columnHeader>

    <detail>
        <band height="42">

            <line>
                <reportElement x="0" y="40" width="515" height="1"/>
                <graphicElement>
                    <pen lineWidth="0.4" lineColor="#E0E0E0"/>
                </graphicElement>
            </line>

            <textField>
                <reportElement x="8" y="6" width="125" height="30"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{medicamento}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="138" y="6" width="75" height="30"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{dosis}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="218" y="6" width="90" height="30"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{frecuencia}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="313" y="6" width="70" height="30"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{duracion}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="388" y="6" width="115" height="30"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{instrucciones}]]></textFieldExpression>
            </textField>

        </band>
    </detail>

    <summary>
        <band height="215">

            <staticText>
                <reportElement x="0" y="20" width="515" height="24" backcolor="#E8505B" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[  INDICACIONES GENERALES]]></text>
            </staticText>

            <rectangle>
                <reportElement x="0" y="44" width="515" height="70" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <textField>
                <reportElement x="20" y="60" width="475" height="40"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{INDICACIONES}]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement x="0" y="130" width="515" height="40" backcolor="#F8F9FA" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="20" y="142" width="475" height="18"/>
                <textElement textAlignment="Center">
                    <font size="8" isItalic="true"/>
                </textElement>
                <text><![CDATA[Presentar este documento en farmacia o consulta médica si es requerido.]]></text>
            </staticText>

            <line>
                <reportElement x="0" y="185" width="515" height="1"/>
            </line>

            <staticText>
                <reportElement x="0" y="195" width="515" height="14"/>
                <textElement textAlignment="Center">
                    <font size="7"/>
                </textElement>
                <text><![CDATA[Documento generado automáticamente por el Sistema Clínica Sanicen.]]></text>
            </staticText>

        </band>
    </summary>

</jasperReport>