<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="boleta_cita"
              pageWidth="595"
              pageHeight="842"
              columnWidth="515"
              leftMargin="40"
              rightMargin="40"
              topMargin="30"
              bottomMargin="30">

    <parameter name="LOGO_PATH" class="java.io.InputStream"/>
    <parameter name="NOMBRE_CLINICA" class="java.lang.String"/>
    <parameter name="RUC" class="java.lang.String"/>
    <parameter name="DIRECCION" class="java.lang.String"/>
    <parameter name="TELEFONO" class="java.lang.String"/>
    <parameter name="FECHA_EMISION" class="java.lang.String"/>

    <parameter name="NUMERO_BOLETA" class="java.lang.String"/>
    <parameter name="PACIENTE" class="java.lang.String"/>
    <parameter name="MEDICO" class="java.lang.String"/>
    <parameter name="ESPECIALIDAD" class="java.lang.String"/>
    <parameter name="FECHA_CITA" class="java.lang.String"/>
    <parameter name="HORA_CITA" class="java.lang.String"/>
    <parameter name="MOTIVO" class="java.lang.String"/>
    <parameter name="FORMA_PAGO" class="java.lang.String"/>
    <parameter name="MONTO" class="java.lang.String"/>
    <parameter name="ESTADO" class="java.lang.String"/>

    <title>
        <band height="760">

            <!-- Franja superior -->
            <rectangle>
                <reportElement x="0" y="0" width="515" height="10" backcolor="#E8505B" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0"/>
                </graphicElement>
            </rectangle>

            <!-- Encabezado principal -->
            <rectangle>
                <reportElement x="0" y="10" width="515" height="95" backcolor="#F8F9FA" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <image>
                <reportElement x="15" y="28" width="75" height="45"/>
                <imageExpression><![CDATA[$P{LOGO_PATH}]]></imageExpression>
            </image>

            <textField>
                <reportElement x="100" y="24" width="230" height="22"/>
                <textElement>
                    <font size="15" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{NOMBRE_CLINICA}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="100" y="48" width="230" height="14"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["RUC: " + $P{RUC}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="100" y="63" width="230" height="14"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{DIRECCION}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="100" y="78" width="230" height="14"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Teléfono: " + $P{TELEFONO}]]></textFieldExpression>
            </textField>

            <!-- Caja de boleta -->
            <rectangle>
                <reportElement x="355" y="25" width="140" height="60" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="1.1" lineColor="#333333"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="355" y="33" width="140" height="18"/>
                <textElement textAlignment="Center">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[BOLETA DE PAGO]]></text>
            </staticText>

            <textField>
                <reportElement x="355" y="56" width="140" height="18"/>
                <textElement textAlignment="Center">
                    <font size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{NUMERO_BOLETA}]]></textFieldExpression>
            </textField>

            <!-- Título -->
            <staticText>
                <reportElement x="0" y="130" width="515" height="28" backcolor="#E8505B" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="13" isBold="true"/>
                </textElement>
                <text><![CDATA[COMPROBANTE DE CITA MÉDICA]]></text>
            </staticText>

            <textField>
                <reportElement x="335" y="170" width="180" height="16"/>
                <textElement textAlignment="Right">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Fecha de emisión: " + $P{FECHA_EMISION}]]></textFieldExpression>
            </textField>

            <!-- Sección paciente -->
            <rectangle>
                <reportElement x="0" y="205" width="515" height="155" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="0" y="205" width="515" height="24" backcolor="#F1F1F1" mode="Opaque"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[  DATOS DEL PACIENTE Y CITA]]></text>
            </staticText>

            <staticText>
                <reportElement x="25" y="245" width="115" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Paciente:]]></text>
            </staticText>

            <textField>
                <reportElement x="150" y="245" width="330" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{PACIENTE}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="272" width="115" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Médico:]]></text>
            </staticText>

            <textField>
                <reportElement x="150" y="272" width="330" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{MEDICO}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="299" width="115" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Especialidad:]]></text>
            </staticText>

            <textField>
                <reportElement x="150" y="299" width="330" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ESPECIALIDAD}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="326" width="115" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Fecha y hora:]]></text>
            </staticText>

            <textField>
                <reportElement x="150" y="326" width="330" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{FECHA_CITA} + " - " + $P{HORA_CITA}]]></textFieldExpression>
            </textField>

            <!-- Motivo -->
            <rectangle>
                <reportElement x="0" y="380" width="515" height="70" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="0" y="380" width="515" height="22" backcolor="#F1F1F1" mode="Opaque"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[  MOTIVO DE LA CITA]]></text>
            </staticText>

            <textField>
                <reportElement x="25" y="415" width="465" height="25"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{MOTIVO}]]></textFieldExpression>
            </textField>

            <!-- Detalle pago -->
            <staticText>
                <reportElement x="0" y="475" width="515" height="24" backcolor="#E8505B" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[  DETALLE DEL PAGO]]></text>
            </staticText>

            <rectangle>
                <reportElement x="0" y="499" width="515" height="95" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="20" y="515" width="250" height="18"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Concepto]]></text>
            </staticText>

            <staticText>
                <reportElement x="360" y="515" width="110" height="18"/>
                <textElement textAlignment="Right">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Importe]]></text>
            </staticText>

            <line>
                <reportElement x="0" y="540" width="515" height="1"/>
            </line>

            <staticText>
                <reportElement x="20" y="555" width="250" height="18"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <text><![CDATA[Pago por cita médica]]></text>
            </staticText>

            <textField>
                <reportElement x="360" y="555" width="110" height="18"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["S/ " + $P{MONTO}]]></textFieldExpression>
            </textField>

            <!-- Forma de pago y estado -->
            <staticText>
                <reportElement x="0" y="615" width="115" height="18"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Forma de pago:]]></text>
            </staticText>

            <textField>
                <reportElement x="120" y="615" width="210" height="18"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{FORMA_PAGO}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="650" width="70" height="18"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Estado:]]></text>
            </staticText>

            <rectangle>
                <reportElement x="70" y="645" width="95" height="26" backcolor="#E8F5E9" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#2E7D32"/>
                </graphicElement>
            </rectangle>

            <textField>
                <reportElement x="70" y="651" width="95" height="16" forecolor="#2E7D32"/>
                <textElement textAlignment="Center">
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ESTADO}]]></textFieldExpression>
            </textField>

            <!-- Total -->
            <rectangle>
                <reportElement x="330" y="625" width="165" height="50" backcolor="#F8F9FA" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="1.0" lineColor="#333333"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="345" y="642" width="55" height="18"/>
                <textElement>
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[TOTAL:]]></text>
            </staticText>

            <textField>
                <reportElement x="400" y="642" width="80" height="18"/>
                <textElement textAlignment="Right">
                    <font size="12" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["S/ " + $P{MONTO}]]></textFieldExpression>
            </textField>

            <!-- Pie -->
            <line>
                <reportElement x="0" y="700" width="515" height="1"/>
            </line>

            <staticText>
                <reportElement x="0" y="712" width="515" height="14"/>
                <textElement textAlignment="Center">
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Gracias por confiar en Clínica Sanicen.]]></text>
            </staticText>

            <staticText>
                <reportElement x="0" y="728" width="515" height="14"/>
                <textElement textAlignment="Center">
                    <font size="7"/>
                </textElement>
                <text><![CDATA[Documento generado automáticamente por el Sistema Clínica Sanicen.]]></text>
            </staticText>

        </band>
    </title>

</jasperReport>