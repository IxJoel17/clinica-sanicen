<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="boleta_cita"
              pageWidth="595"
              pageHeight="842"
              columnWidth="515"
              leftMargin="40"
              rightMargin="40"
              topMargin="30"
              bottomMargin="30">

    <parameter name="LOGO_PATH" class="java.io.InputStream"/>
    <parameter name="NOMBRE_CLINICA" class="java.lang.String"/>
    <parameter name="FECHA_EMISION" class="java.lang.String"/>
    <parameter name="NUMERO_CITA" class="java.lang.String"/>

    <parameter name="PACIENTE" class="java.lang.String"/>
    <parameter name="DNI" class="java.lang.String"/>
    <parameter name="MEDICO" class="java.lang.String"/>
    <parameter name="ESPECIALIDAD" class="java.lang.String"/>
    <parameter name="FECHA_CITA" class="java.lang.String"/>
    <parameter name="HORA_CITA" class="java.lang.String"/>
    <parameter name="MOTIVO" class="java.lang.String"/>
    <parameter name="ESTADO" class="java.lang.String"/>

    <title>
        <band height="760">

            <!-- Línea superior roja -->
            <rectangle>
                <reportElement x="0" y="0" width="515" height="10" backcolor="#E8505B" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0"/>
                </graphicElement>
            </rectangle>

            <!-- Encabezado -->
            <rectangle>
                <reportElement x="0" y="10" width="515" height="105" backcolor="#F8F9FA" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <image onErrorType="Blank">
                <reportElement x="18" y="32" width="75" height="45"/>
                <imageExpression><![CDATA[$P{LOGO_PATH}]]></imageExpression>
            </image>

            <textField>
                <reportElement x="105" y="28" width="240" height="22"/>
                <textElement>
                    <font size="16" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{NOMBRE_CLINICA}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="105" y="53" width="240" height="14"/>
                <textElement>
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Documento de comprobante de cita médica]]></text>
            </staticText>

            <textField>
                <reportElement x="105" y="72" width="240" height="14"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Fecha de emisión: " + $P{FECHA_EMISION}]]></textFieldExpression>
            </textField>

            <!-- Caja número cita -->
            <rectangle>
                <reportElement x="365" y="28" width="130" height="60" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="1.1" lineColor="#333333"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="365" y="38" width="130" height="18"/>
                <textElement textAlignment="Center">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[CITA MÉDICA]]></text>
            </staticText>

            <textField>
                <reportElement x="365" y="62" width="130" height="18"/>
                <textElement textAlignment="Center">
                    <font size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["CM-" + $P{NUMERO_CITA}]]></textFieldExpression>
            </textField>

            <!-- Título -->
            <staticText>
                <reportElement x="0" y="145" width="515" height="28" backcolor="#E8505B" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="13" isBold="true"/>
                </textElement>
                <text><![CDATA[COMPROBANTE DE CITA MÉDICA]]></text>
            </staticText>

            <!-- Datos del paciente -->
            <rectangle>
                <reportElement x="0" y="205" width="515" height="125" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="0" y="205" width="515" height="25" backcolor="#F1F1F1" mode="Opaque"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[  DATOS DEL PACIENTE]]></text>
            </staticText>

            <staticText>
                <reportElement x="25" y="255" width="120" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Paciente:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="255" width="330" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{PACIENTE}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="282" width="120" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[DNI:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="282" width="330" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{DNI}]]></textFieldExpression>
            </textField>

            <!-- Datos atención -->
            <rectangle>
                <reportElement x="0" y="360" width="515" height="200" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="0" y="360" width="515" height="25" backcolor="#F1F1F1" mode="Opaque"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[  DATOS DE LA ATENCIÓN]]></text>
            </staticText>

            <staticText>
                <reportElement x="25" y="405" width="120" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Médico:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="405" width="330" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{MEDICO}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="432" width="120" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Especialidad:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="432" width="330" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ESPECIALIDAD}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="459" width="120" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Fecha:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="459" width="330" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{FECHA_CITA}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="486" width="120" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Hora:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="486" width="330" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{HORA_CITA}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="513" width="120" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Motivo:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="513" width="330" height="18"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{MOTIVO}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="540" width="120" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Estado:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="540" width="130" height="18" forecolor="#2E7D32"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ESTADO}]]></textFieldExpression>
            </textField>

            <!-- Indicaciones -->
            <staticText>
                <reportElement x="0" y="595" width="515" height="24" backcolor="#E8505B" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[  INDICACIONES]]></text>
            </staticText>

            <rectangle>
                <reportElement x="0" y="619" width="515" height="70" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="25" y="642" width="465" height="28"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <text><![CDATA[Presentar este comprobante al momento de asistir a la consulta médica. Llegar con 10 minutos de anticipación.]]></text>
            </staticText>

            <!-- Pie -->
            <line>
                <reportElement x="0" y="720" width="515" height="1"/>
            </line>

            <staticText>
                <reportElement x="0" y="735" width="515" height="12"/>
                <textElement textAlignment="Center">
                    <font size="7"/>
                </textElement>
                <text><![CDATA[Documento generado automáticamente por el Sistema Clínica Sanicen.]]></text>
            </staticText>

        </band>
    </title>

</jasperReport>