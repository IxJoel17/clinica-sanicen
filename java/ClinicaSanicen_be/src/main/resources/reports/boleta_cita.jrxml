<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="boleta_cita"
              pageWidth="595"
              pageHeight="842"
              columnWidth="515"
              leftMargin="40"
              rightMargin="40"
              topMargin="30"
              bottomMargin="30">

    <parameter name="LOGO_PATH" class="java.io.InputStream"/>
    <parameter name="NOMBRE_CLINICA" class="java.lang.String"/>
    <parameter name="RUC" class="java.lang.String"/>
    <parameter name="DIRECCION" class="java.lang.String"/>
    <parameter name="TELEFONO" class="java.lang.String"/>
    <parameter name="FECHA_EMISION" class="java.lang.String"/>

    <parameter name="NUMERO_BOLETA" class="java.lang.String"/>
    <parameter name="PACIENTE" class="java.lang.String"/>
    <parameter name="MEDICO" class="java.lang.String"/>
    <parameter name="ESPECIALIDAD" class="java.lang.String"/>
    <parameter name="FECHA_CITA" class="java.lang.String"/>
    <parameter name="HORA_CITA" class="java.lang.String"/>
    <parameter name="MOTIVO" class="java.lang.String"/>
    <parameter name="FORMA_PAGO" class="java.lang.String"/>
    <parameter name="MONTO" class="java.lang.String"/>
    <parameter name="ESTADO" class="java.lang.String"/>

    <title>
        <band height="730">

            <rectangle>
                <reportElement x="0" y="0" width="515" height="90" backcolor="#F8F9FA"/>
                <graphicElement>
                    <pen lineWidth="1.0" lineColor="#DDDDDD"/>
                </graphicElement>
            </rectangle>

            <image>
                <reportElement x="15" y="15" width="60" height="60"/>
                <imageExpression><![CDATA[$P{LOGO_PATH}]]></imageExpression>
            </image>

            <textField>
                <reportElement x="85" y="15" width="250" height="25"/>
                <textElement>
                    <font size="16" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{NOMBRE_CLINICA}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="85" y="42" width="250" height="15"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["RUC: " + $P{RUC}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="85" y="58" width="250" height="15"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{DIRECCION}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="85" y="73" width="250" height="15"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["Teléfono: " + $P{TELEFONO}]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement x="365" y="15" width="130" height="60" backcolor="#FFFFFF"/>
                <graphicElement>
                    <pen lineWidth="1.0" lineColor="#333333"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="365" y="22" width="130" height="18"/>
                <textElement textAlignment="Center">
                    <font size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[BOLETA DE PAGO]]></text>
            </staticText>

            <textField>
                <reportElement x="365" y="45" width="130" height="18"/>
                <textElement textAlignment="Center">
                    <font size="10" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{NUMERO_BOLETA}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="120" width="515" height="25" backcolor="#E8505B"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="14" isBold="true"/>
                </textElement>
                <text><![CDATA[COMPROBANTE DE CITA MÉDICA]]></text>
            </staticText>

            <textField>
                <reportElement x="350" y="160" width="165" height="18"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["Fecha de emisión: " + $P{FECHA_EMISION}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="200" width="515" height="22" backcolor="#F1F1F1"/>
                <textElement verticalAlignment="Middle">
                    <font size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[  DATOS DEL PACIENTE Y CITA]]></text>
            </staticText>

            <staticText>
                <reportElement x="20" y="240" width="120" height="18"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Paciente:]]></text>
            </staticText>

            <textField>
                <reportElement x="150" y="240" width="330" height="18"/>
                <textFieldExpression><![CDATA[$P{PACIENTE}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="20" y="270" width="120" height="18"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Médico:]]></text>
            </staticText>

            <textField>
                <reportElement x="150" y="270" width="330" height="18"/>
                <textFieldExpression><![CDATA[$P{MEDICO}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="20" y="300" width="120" height="18"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Especialidad:]]></text>
            </staticText>

            <textField>
                <reportElement x="150" y="300" width="330" height="18"/>
                <textFieldExpression><![CDATA[$P{ESPECIALIDAD}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="20" y="330" width="120" height="18"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Fecha y hora:]]></text>
            </staticText>

            <textField>
                <reportElement x="150" y="330" width="330" height="18"/>
                <textFieldExpression><![CDATA[$P{FECHA_CITA} + " - " + $P{HORA_CITA}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="20" y="360" width="120" height="18"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Motivo:]]></text>
            </staticText>

            <textField>
                <reportElement x="150" y="360" width="330" height="35"/>
                <textFieldExpression><![CDATA[$P{MOTIVO}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="430" width="515" height="22" backcolor="#F1F1F1"/>
                <textElement verticalAlignment="Middle">
                    <font size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[  DETALLE DEL PAGO]]></text>
            </staticText>

            <rectangle>
                <reportElement x="20" y="470" width="475" height="80"/>
                <graphicElement>
                    <pen lineWidth="0.8" lineColor="#CCCCCC"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="35" y="485" width="180" height="18"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Concepto]]></text>
            </staticText>

            <staticText>
                <reportElement x="330" y="485" width="120" height="18"/>
                <textElement textAlignment="Right">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Importe]]></text>
            </staticText>

            <line>
                <reportElement x="20" y="510" width="475" height="1"/>
            </line>

            <staticText>
                <reportElement x="35" y="525" width="250" height="18"/>
                <text><![CDATA[Pago por cita médica]]></text>
            </staticText>

            <textField>
                <reportElement x="330" y="525" width="120" height="18"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA["S/ " + $P{MONTO}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="20" y="575" width="130" height="18"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Forma de pago:]]></text>
            </staticText>

            <textField>
                <reportElement x="150" y="575" width="250" height="18"/>
                <textFieldExpression><![CDATA[$P{FORMA_PAGO}]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement x="315" y="610" width="180" height="40" backcolor="#F8F9FA"/>
                <graphicElement>
                    <pen lineWidth="1.0" lineColor="#333333"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="330" y="622" width="60" height="18"/>
                <textElement>
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[TOTAL:]]></text>
            </staticText>

            <textField>
                <reportElement x="390" y="622" width="90" height="18"/>
                <textElement textAlignment="Right">
                    <font size="12" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["S/ " + $P{MONTO}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="20" y="625" width="180" height="20"/>
                <textElement>
                    <font size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Estado: " + $P{ESTADO}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="0" y="680" width="515" height="1"/>
            </line>

            <staticText>
                <reportElement x="0" y="695" width="515" height="18"/>
                <textElement textAlignment="Center">
                    <font size="9"/>
                </textElement>
                <text><![CDATA[Documento generado automáticamente por el Sistema Clínica Sanicen.]]></text>
            </staticText>

        </band>
    </title>

</jasperReport>