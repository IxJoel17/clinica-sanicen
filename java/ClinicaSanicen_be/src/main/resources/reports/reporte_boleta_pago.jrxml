<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="reporte_boleta_pago"
              pageWidth="595"
              pageHeight="842"
              columnWidth="515"
              leftMargin="40"
              rightMargin="40"
              topMargin="30"
              bottomMargin="30">

    <parameter name="LOGO_PATH" class="java.io.InputStream"/>

    <parameter name="NOMBRE_CLINICA" class="java.lang.String"/>
    <parameter name="RUC" class="java.lang.String"/>
    <parameter name="DIRECCION" class="java.lang.String"/>
    <parameter name="TELEFONO" class="java.lang.String"/>

    <parameter name="ID_BOLETA" class="java.lang.String"/>
    <parameter name="FECHA_EMISION" class="java.lang.String"/>
    <parameter name="PACIENTE" class="java.lang.String"/>
    <parameter name="MEDICO" class="java.lang.String"/>
    <parameter name="ESPECIALIDAD" class="java.lang.String"/>
    <parameter name="FECHA_CITA" class="java.lang.String"/>
    <parameter name="HORA_CITA" class="java.lang.String"/>
    <parameter name="MOTIVO" class="java.lang.String"/>
    <parameter name="MONTO" class="java.lang.String"/>
    <parameter name="METODO_PAGO" class="java.lang.String"/>
    <parameter name="ESTADO" class="java.lang.String"/>

    <title>
        <band height="770">

            <!-- Línea superior roja -->
            <rectangle>
                <reportElement x="0" y="0" width="515" height="10" backcolor="#E8505B" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0"/>
                </graphicElement>
            </rectangle>

            <!-- Encabezado -->
            <rectangle>
                <reportElement x="0" y="10" width="515" height="105" backcolor="#F8F9FA" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <image>
                <reportElement x="18" y="32" width="75" height="45"/>
                <imageExpression><![CDATA[$P{LOGO_PATH}]]></imageExpression>
            </image>

            <textField>
                <reportElement x="105" y="28" width="240" height="22"/>
                <textElement>
                    <font size="16" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{NOMBRE_CLINICA}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="105" y="53" width="240" height="14"/>
                <textElement>
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Documento de boleta de pago electrónica]]></text>
            </staticText>

            <textField>
                <reportElement x="105" y="72" width="240" height="14"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Fecha de emisión: " + $P{FECHA_EMISION}]]></textFieldExpression>
            </textField>

            <!-- Caja número boleta -->
            <rectangle>
                <reportElement x="365" y="28" width="130" height="60" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="1.1" lineColor="#333333"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="365" y="38" width="130" height="18"/>
                <textElement textAlignment="Center">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[BOLETA DE PAGO]]></text>
            </staticText>

            <textField>
                <reportElement x="365" y="62" width="130" height="18"/>
                <textElement textAlignment="Center">
                    <font size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["BP-" + $P{ID_BOLETA}]]></textFieldExpression>
            </textField>

            <!-- Título central -->
            <staticText>
                <reportElement x="0" y="145" width="515" height="28" backcolor="#E8505B" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="13" isBold="true"/>
                </textElement>
                <text><![CDATA[COMPROBANTE DE PAGO DE CITA MÉDICA]]></text>
            </staticText>

            <!-- Datos principales -->
            <rectangle>
                <reportElement x="0" y="205" width="515" height="140" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="0" y="205" width="515" height="25" backcolor="#F1F1F1" mode="Opaque"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[  DATOS DE LA BOLETA]]></text>
            </staticText>

            <staticText>
                <reportElement x="25" y="250" width="120" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Paciente:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="250" width="330" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{PACIENTE}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="277" width="120" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Método de pago:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="277" width="330" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{METODO_PAGO}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="304" width="120" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Estado:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="304" width="130" height="18" forecolor="#2E7D32"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ESTADO}]]></textFieldExpression>
            </textField>

            <!-- Datos atención -->
            <rectangle>
                <reportElement x="0" y="370" width="515" height="150" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="0" y="370" width="515" height="25" backcolor="#F1F1F1" mode="Opaque"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[  DATOS DE LA ATENCIÓN]]></text>
            </staticText>

            <staticText>
                <reportElement x="25" y="410" width="120" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Médico:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="410" width="330" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{MEDICO}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="437" width="120" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Especialidad:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="437" width="330" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ESPECIALIDAD}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="464" width="120" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Fecha y hora:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="464" width="330" height="16"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{FECHA_CITA} + " - " + $P{HORA_CITA}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="25" y="491" width="120" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Motivo:]]></text>
            </staticText>

            <textField>
                <reportElement x="155" y="491" width="330" height="18"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{MOTIVO}]]></textFieldExpression>
            </textField>

            <!-- Detalle del pago -->
            <staticText>
                <reportElement x="0" y="545" width="515" height="24" backcolor="#E8505B" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[  DETALLE DEL PAGO]]></text>
            </staticText>

            <rectangle>
                <reportElement x="0" y="569" width="515" height="95" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.7" lineColor="#D9D9D9"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="20" y="590" width="250" height="18"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Concepto]]></text>
            </staticText>

            <staticText>
                <reportElement x="365" y="590" width="110" height="18"/>
                <textElement textAlignment="Right">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Importe]]></text>
            </staticText>

            <line>
                <reportElement x="0" y="615" width="515" height="1"/>
            </line>

            <staticText>
                <reportElement x="20" y="630" width="250" height="18"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <text><![CDATA[Pago por cita médica]]></text>
            </staticText>

            <textField>
                <reportElement x="365" y="630" width="110" height="18"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{MONTO}]]></textFieldExpression>
            </textField>

            <!-- Total -->
            <rectangle>
                <reportElement x="330" y="690" width="165" height="45" backcolor="#F8F9FA" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="1.0" lineColor="#333333"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="345" y="705" width="55" height="18"/>
                <textElement>
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[TOTAL:]]></text>
            </staticText>

            <textField>
                <reportElement x="400" y="705" width="80" height="18"/>
                <textElement textAlignment="Right">
                    <font size="12" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{MONTO}]]></textFieldExpression>
            </textField>

            <!-- Pie -->
            <line>
                <reportElement x="0" y="745" width="515" height="1"/>
            </line>

            <staticText>
                <reportElement x="0" y="755" width="515" height="12"/>
                <textElement textAlignment="Center">
                    <font size="7"/>
                </textElement>
                <text><![CDATA[Documento generado automáticamente por el Sistema Clínica Sanicen.]]></text>
            </staticText>

        </band>
    </title>

</jasperReport>